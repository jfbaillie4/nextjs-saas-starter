# -----------------------------------------------
# Clerk — https://dashboard.clerk.com
# Create an application, then find these keys under "API Keys"
# -----------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# These tell Clerk which pages to use for auth flows — do not change
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/org-selection
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/org-selection

# -----------------------------------------------
# Database — https://neon.tech (recommended) or https://supabase.com
# Create a project, then copy the connection string from the dashboard
# -----------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
